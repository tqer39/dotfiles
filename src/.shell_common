#!/bin/bash
# ------------------------------------------------------------------------------
# .shell_common - Shared configuration for bash and zsh
# ------------------------------------------------------------------------------
# This file is sourced by both .bashrc and .zshrc
# Shell-specific settings should remain in their respective files

# ------------------------------------------------------------------------------
# Aliases
# ------------------------------------------------------------------------------

# Help function
alias_help() {
  cat << 'EOF'
Aliases:
  Navigation:
    ..        cd ..
    ...       cd ../..
    work      cd ~/workspace
    z         zoxide (smart cd)

  Git:
    g         git
    ga        git add
    gc        git commit
    gd        git diff
    gpl       git pull
    gps       git push
    gs        git status
    gsw       git switch
    gl        git log --oneline
    gnf       git new-feature-branch
    gclean    delete stale local branches (-f to force)

  Files:
    ls        eza --icons
    ll        eza -la (long)
    lt        eza -T (tree)
    cat       bat

  Container:
    docker    podman (if installed)
    docker-compose  podman compose (if installed)

  Zellij:
    zj        attach/create zellij session (default layout)
    zj <name> attach/create named session; inside zellij → switch-session
EOF
}

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias work='cd ~/workspace'

# Git
if command -v git &> /dev/null; then
  alias g='git'
  alias ga='git add'
  alias gc='git commit'
  alias gd='git diff'
  alias gpl='git pull'
  alias gps='git push'
  alias gs='git status'
  alias gsw='git switch'
  alias gl='git log --oneline -20'
  alias gnf='git new-feature-branch'

  # Clean up local branches deleted on remote
  # Usage: gclean [-f|--force]
  git_cleanup_branches() {
    local force=false
    if [[ "${1:-}" == "-f" || "${1:-}" == "--force" ]]; then
      force=true
    fi

    git fetch -p
    local branches
    branches=$(git branch -vv | grep ': gone]' | awk '{print $1}')
    if [[ -z "$branches" ]]; then
      echo "No stale branches to clean up."
      return 0
    fi
    echo "Deleting stale branches:"
    echo "$branches"
    if [[ "$force" == true ]]; then
      echo "$branches" | xargs git branch -D
    else
      echo "$branches" | xargs git branch -d
    fi
  }
  alias gclean='git_cleanup_branches'
fi

# eza (ls replacement)
if command -v eza &> /dev/null; then
  alias ls='eza --icons --git'
  alias ll='eza -la --icons --git'
  alias lt='eza -T -L 2 --icons'
fi

# bat (cat replacement)
if command -v bat &> /dev/null; then
  alias cat='bat'
fi

# Podman (Docker compatibility)
if command -v podman &> /dev/null; then
  alias docker='podman'
  alias docker-compose='podman compose'
fi

# Zellij
if command -v zellij &> /dev/null; then
  zj() {
    local name="${1:-}"
    local sessions
    sessions="$(zellij list-sessions --no-formatting 2>/dev/null || true)"
    if [ -n "$name" ] && printf '%s\n' "$sessions" | grep -q "^${name} .*EXITED"; then
      zellij delete-session "$name" >/dev/null 2>&1 || true
      sessions="$(zellij list-sessions --no-formatting 2>/dev/null || true)"
    fi

    if [ -n "${ZELLIJ:-}" ]; then
      if [ -z "$name" ]; then
        echo "zj: already inside zellij session '${ZELLIJ_SESSION_NAME:-?}'" >&2
        return 0
      fi
      if [ "${ZELLIJ_SESSION_NAME:-}" = "$name" ]; then
        echo "zj: already in session '$name'" >&2
        return 0
      fi
      if printf '%s\n' "$sessions" | grep -q "^${name} "; then
        zellij action switch-session "$name"
      else
        echo "zj: session '$name' not found. detach (Ctrl-o d) first, then run: zj $name" >&2
        return 1
      fi
      return
    fi

    if [ -z "$name" ]; then
      zellij attach 2>/dev/null || zellij
    elif printf '%s\n' "$sessions" | grep -q "^${name} "; then
      zellij attach "$name"
    else
      zellij --session "$name"
    fi
  }

  # Set terminal title to cwd (shows in zellij tab-bar).
  _zj_last_cwd=""
  _zj_set_title() {
    [ -z "${ZELLIJ:-}" ] && return 0
    [ "$PWD" = "${_zj_last_cwd:-}" ] && return 0
    _zj_last_cwd="$PWD"
    printf '\033]0;%s\007' "${PWD/#$HOME/~}"
  }
  if [ -n "${ZSH_VERSION:-}" ]; then
    autoload -Uz add-zsh-hook 2>/dev/null && add-zsh-hook chpwd _zj_set_title
    _zj_set_title
  elif [ -n "${BASH_VERSION:-}" ]; then
    case "${PROMPT_COMMAND:-}" in
      *_zj_set_title*) ;;
      *) PROMPT_COMMAND="_zj_set_title${PROMPT_COMMAND:+; $PROMPT_COMMAND}" ;;
    esac
  fi
fi

# pbcopy/pbpaste (Linux)
if command -v xsel &> /dev/null; then
  alias pbcopy='xsel --clipboard --input'
  alias pbpaste='xsel --clipboard --output'
fi

# ------------------------------------------------------------------------------
# Common tool initialization
# ------------------------------------------------------------------------------

# Homebrew
if [[ "$(uname)" = "Linux" ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [[ "$(uname)" = "Darwin" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Cargo/Rust
# shellcheck source=/dev/null
if [ -f "$HOME/.cargo/env" ]; then
  . "$HOME/.cargo/env"
fi
