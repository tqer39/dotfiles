// Default layout
// - tab-bar (top): shows tabs with cwd via terminal title (OSC 0)
// - status-bar (bottom): shows keybinding hints per mode
// - cwd is set as terminal title from precmd/chpwd hooks in .shell_common

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="main" {
        pane name="shell" focus=true
    }
}
