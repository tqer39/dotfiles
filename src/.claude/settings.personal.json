{
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "deny": [
      "Bash(gh repo delete:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git add .)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(//Users/*/.aws/credentials)",
      "Read(//Users/*/.aws/config)",
      "Read(//Users/*/.ssh/id_*)",
      "Read(//Users/*/.ssh/*.pem)",
      "Read(//Users/*/.netrc)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/require-worktree.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "git@tqer39-plugins": true,
    "architecture@tqer39-plugins": true,
    "agent-config@tqer39-plugins": true,
    "skill-matcher@tqer39-plugins": true,
    "discord@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "tqer39-plugins": {
      "source": {
        "source": "github",
        "repo": "tqer39/claude-code-marketplace"
      }
    }
  },
  "language": "日本語",
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true
}
